# ========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ========================================

# ▶️ VITE DEV SERVER
# The port where the frontend development server runs
VITE_PORT=8083

# 🔗 BACKEND API
# URL of the backend API server
# For local development: http://localhost:5000
# For production: https://api.bynixx.com
VITE_API_URL=http://localhost:5000

# 📡 API ENDPOINTS
# These are the actual endpoint paths
VITE_API_BASE_PATH=/api

# ✅ Authentication
VITE_AUTH_ENDPOINT=/api/auth

# 👥 Users
VITE_USERS_ENDPOINT=/api/users

# 📚 Courses
VITE_COURSES_ENDPOINT=/api/courses

# 📝 Tasks
VITE_TASKS_ENDPOINT=/api/tasks

# 🎥 Live Sessions
VITE_SESSIONS_ENDPOINT=/api/sessions

# 📊 Analytics
VITE_ANALYTICS_ENDPOINT=/api/analytics

# ========================================
# DEVELOPMENT/PRODUCTION FLAGS
# ========================================

# NODE_ENV is set by Vite automatically
# Set to 'development', 'test', or 'production'

# Enable detailed logging in development
VITE_DEBUG=true

# ========================================
# EXTERNAL SERVICES (Optional)
# ========================================

# 🎮 Zoom Integration (for live sessions)
# VITE_ZOOM_API_KEY=your_zoom_api_key
# VITE_ZOOM_API_SECRET=your_zoom_api_secret

# 📧 Email Service (for notifications)
# VITE_SENDGRID_API_KEY=your_sendgrid_key

# 💬 WebRTC Signaling Server
# VITE_WEBRTC_SERVER=wss://webrtc.bynixx.com

# ========================================
# NOTES
# ========================================
# 1. All VITE_* variables are exposed to the browser
# 2. Sensitive keys (API keys, tokens) should NOT be prefixed with VITE_
# 3. Keep sensitive keys on the backend only
# 4. When deploying, update VITE_API_URL to production backend
# 5. Local development uses http://localhost:5000 by default
